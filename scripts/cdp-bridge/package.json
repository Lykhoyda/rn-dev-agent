{
  "name": "rn-dev-agent-cdp",
  "version": "0.50.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:web": "cd src/observability/web && npm install && npm run build",
    "dev": "tsc --watch",
    "test": "npm run build && node --test 'test/unit/*.test.js' 'test/unit/**/*.test.js'",
    "test:integration": "npm run build && node --test 'test/integration/*.test.js'",
    "test:all": "npm run build && node --test 'test/unit/*.test.js' 'test/unit/**/*.test.js' 'test/integration/*.test.js'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "fast-uri": ">=3.1.2",
    "hono": ">=4.12.18",
    "ip-address": ">=10.1.1"
  }
}
