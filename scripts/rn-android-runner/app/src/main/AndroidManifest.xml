<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        INTERNET is required at the TARGET APP level (not just androidTest).
        `am instrument` injects test code into this app's process, and NanoHTTPD's
        ServerSocket.bind() checks the target UID's permissions, not the test APK's.
        Discovered live during Task 10 smoke-test (EPERM on socket bind).
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:label="rn-dev-agent Android runner"
        android:theme="@android:style/Theme.Material.Light.NoActionBar" />
</manifest>
