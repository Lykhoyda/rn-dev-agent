{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "acceptanceMappings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "criterion": {
            "minLength": 1,
            "type": "string"
          },
          "storyboardStepIds": {
            "items": {
              "pattern": "^[a-z0-9-]+$",
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "criterion",
          "storyboardStepIds"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "action": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "assertions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "ok": {
            "const": true,
            "type": "boolean"
          },
          "resultHash": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "stepId": {
            "pattern": "^[a-z0-9-]+$",
            "type": "string"
          },
          "tool": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "stepId",
          "tool",
          "ok",
          "resultHash"
        ],
        "type": "object"
      },
      "minItems": 3,
      "type": "array"
    },
    "authority": {
      "additionalProperties": false,
      "properties": {
        "authorityVersion": {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        "bundle": {
          "additionalProperties": false,
          "properties": {
            "authorityScope": {
              "const": "initial-bundle",
              "type": "string"
            },
            "connectionGeneration": {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            "markerDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "sourceFidelity": {
              "const": "not-proven",
              "type": "string"
            },
            "targetId": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "targetId",
            "connectionGeneration",
            "markerDigest",
            "authorityScope",
            "sourceFidelity"
          ],
          "type": "object"
        },
        "claimEpoch": {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        "controller": {
          "additionalProperties": false,
          "properties": {
            "birthDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "instanceId": {
              "minLength": 1,
              "type": "string"
            },
            "pid": {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "instanceId",
            "pid",
            "birthDigest"
          ],
          "type": "object"
        },
        "device": {
          "additionalProperties": false,
          "properties": {
            "deviceId": {
              "minLength": 1,
              "type": "string"
            },
            "platform": {
              "enum": [
                "ios",
                "android"
              ],
              "type": "string"
            }
          },
          "required": [
            "platform",
            "deviceId"
          ],
          "type": "object"
        },
        "install": {
          "additionalProperties": false,
          "properties": {
            "appId": {
              "minLength": 1,
              "type": "string"
            },
            "artifactDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "buildGeneration": {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "artifactDigest",
            "buildGeneration",
            "appId"
          ],
          "type": "object"
        },
        "metro": {
          "additionalProperties": false,
          "properties": {
            "birthDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "buildGeneration": {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            "instanceId": {
              "minLength": 1,
              "type": "string"
            },
            "pid": {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            "port": {
              "exclusiveMinimum": 0,
              "maximum": 65535,
              "type": "integer"
            }
          },
          "required": [
            "port",
            "instanceId",
            "pid",
            "birthDigest",
            "buildGeneration"
          ],
          "type": "object"
        },
        "proof": {
          "additionalProperties": false,
          "properties": {
            "runId": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "runId"
          ],
          "type": "object"
        },
        "runner": {
          "additionalProperties": false,
          "properties": {
            "capabilityDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "instanceId": {
              "minLength": 1,
              "type": "string"
            },
            "processBirthDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "protocolVersion": {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "instanceId",
            "protocolVersion",
            "capabilityDigest",
            "processBirthDigest"
          ],
          "type": "object"
        },
        "sessionId": {
          "minLength": 1,
          "type": "string"
        },
        "source": {
          "additionalProperties": false,
          "properties": {
            "appRootKey": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "dirtyDigest": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "head": {
              "pattern": "^[0-9a-f]{7,64}$",
              "type": "string"
            },
            "sourceKey": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "worktreeKey": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            }
          },
          "required": [
            "sourceKey",
            "worktreeKey",
            "appRootKey",
            "head",
            "dirtyDigest"
          ],
          "type": "object"
        }
      },
      "required": [
        "sessionId",
        "claimEpoch",
        "authorityVersion",
        "controller",
        "source",
        "install",
        "metro",
        "bundle",
        "device",
        "runner",
        "proof"
      ],
      "type": "object"
    },
    "candidateRuntime": {
      "additionalProperties": false,
      "properties": {
        "coreBundleSha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "mcp": {
          "additionalProperties": false,
          "properties": {
            "argv": {
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "type": "array"
            },
            "cwd": {
              "minLength": 1,
              "type": "string"
            },
            "pid": {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "pid",
            "argv",
            "cwd"
          ],
          "type": "object"
        },
        "repo": {
          "const": "Lykhoyda/rn-dev-agent",
          "type": "string"
        },
        "runnerManifestSha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "sha": {
          "pattern": "^[0-9a-f]{7,64}$",
          "type": "string"
        }
      },
      "required": [
        "repo",
        "sha",
        "coreBundleSha256",
        "runnerManifestSha256",
        "mcp"
      ],
      "type": "object"
    },
    "contactSheet": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256"
      ],
      "type": "object"
    },
    "device": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "model": {
          "minLength": 1,
          "type": "string"
        },
        "osVersion": {
          "minLength": 1,
          "type": "string"
        },
        "platform": {
          "enum": [
            "ios",
            "android"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "platform",
        "model",
        "osVersion"
      ],
      "type": "object"
    },
    "errorBaseline": {
      "additionalProperties": false,
      "properties": {
        "afterCount": {
          "minimum": 0,
          "type": "integer"
        },
        "afterSha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "beforeCount": {
          "minimum": 0,
          "type": "integer"
        },
        "beforeSha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "clean": {
          "const": true,
          "type": "boolean"
        }
      },
      "required": [
        "beforeSha256",
        "afterSha256",
        "beforeCount",
        "afterCount",
        "clean"
      ],
      "type": "object"
    },
    "eventTrace": {
      "additionalProperties": false,
      "properties": {
        "allowedTools": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "observed": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "argsHash": {
                "type": "string"
              },
              "authorityReceiptHash": {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              "durationMs": {
                "minimum": 0,
                "type": "number"
              },
              "ok": {
                "type": "boolean"
              },
              "tool": {
                "type": "string"
              },
              "ts": {
                "type": "integer"
              }
            },
            "required": [
              "tool",
              "ok",
              "ts",
              "durationMs",
              "authorityReceiptHash"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "allowedTools",
        "observed"
      ],
      "type": "object"
    },
    "evidenceReview": {
      "additionalProperties": false,
      "properties": {
        "debuggingFriction": {
          "const": false,
          "type": "boolean"
        },
        "evidenceSha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "exactFeature": {
          "const": true,
          "type": "boolean"
        },
        "independent": {
          "const": true,
          "type": "boolean"
        },
        "irrelevantScreens": {
          "const": false,
          "type": "boolean"
        },
        "personalData": {
          "const": false,
          "type": "boolean"
        },
        "provider": {
          "minLength": 1,
          "type": "string"
        },
        "resultHash": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "writerProvider": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "provider",
        "writerProvider",
        "independent",
        "exactFeature",
        "irrelevantScreens",
        "debuggingFriction",
        "personalData",
        "evidenceSha256",
        "resultHash"
      ],
      "type": "object"
    },
    "fixture": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "frameMatches": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "score": {
            "maximum": 1,
            "minimum": 0,
            "type": "number"
          },
          "screenshotSha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "stepId": {
            "pattern": "^[a-z0-9-]+$",
            "type": "string"
          },
          "videoTimestampMs": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "stepId",
          "screenshotSha256",
          "videoTimestampMs",
          "score"
        ],
        "type": "object"
      },
      "minItems": 3,
      "type": "array"
    },
    "git": {
      "additionalProperties": false,
      "properties": {
        "dirty": {
          "type": "boolean"
        },
        "proofHeadSha": {
          "pattern": "^[0-9a-f]{7,64}$",
          "type": "string"
        },
        "sourceTreeSha": {
          "pattern": "^[0-9a-f]{7,64}$",
          "type": "string"
        }
      },
      "required": [
        "sourceTreeSha",
        "proofHeadSha",
        "dirty"
      ],
      "type": "object"
    },
    "invalidationReasons": {
      "items": {
        "pattern": "^[A-Z0-9_]+$",
        "type": "string"
      },
      "maxItems": 0,
      "minItems": 0,
      "type": "array"
    },
    "issue": {
      "additionalProperties": false,
      "properties": {
        "number": {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        "repository": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "repository",
        "number"
      ],
      "type": "object"
    },
    "proofClass": {
      "enum": [
        "feature",
        "tooling",
        "regression"
      ],
      "type": "string"
    },
    "pullRequest": {
      "additionalProperties": false,
      "properties": {
        "headSha": {
          "pattern": "^[0-9a-f]{7,64}$",
          "type": "string"
        },
        "number": {
          "exclusiveMinimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "number",
        "headSha"
      ],
      "type": "object"
    },
    "rehearsal": {
      "additionalProperties": false,
      "properties": {
        "clean": {
          "const": true,
          "type": "boolean"
        },
        "durationMs": {
          "minimum": 0,
          "type": "number"
        },
        "finishedAt": {
          "pattern": "^((\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-((0[13578]|1[02])-(0[1-9]|[12]\\d|3[01])|(0[469]|11)-(0[1-9]|[12]\\d|30)|(02)-(0[1-9]|1\\d|2[0-8])))T([01]\\d|2[0-3]):[0-5]\\d(:[0-5]\\d(\\.\\d+)?)?(Z)$",
          "type": "string"
        },
        "startedAt": {
          "pattern": "^((\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-((0[13578]|1[02])-(0[1-9]|[12]\\d|3[01])|(0[469]|11)-(0[1-9]|[12]\\d|30)|(02)-(0[1-9]|1\\d|2[0-8])))T([01]\\d|2[0-3]):[0-5]\\d(:[0-5]\\d(\\.\\d+)?)?(Z)$",
          "type": "string"
        }
      },
      "required": [
        "startedAt",
        "finishedAt",
        "durationMs",
        "clean"
      ],
      "type": "object"
    },
    "runId": {
      "minLength": 1,
      "type": "string"
    },
    "runtime": {
      "additionalProperties": false,
      "properties": {
        "bundleId": {
          "minLength": 1,
          "type": "string"
        },
        "metroPort": {
          "exclusiveMinimum": 0,
          "maximum": 65535,
          "type": "integer"
        },
        "metroReady": {
          "type": "boolean"
        },
        "pluginVersion": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "bundleId",
        "metroPort",
        "metroReady",
        "pluginVersion"
      ],
      "type": "object"
    },
    "schemaVersion": {
      "const": 2,
      "type": "number"
    },
    "screenshots": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "stepId": {
            "pattern": "^[a-z0-9-]+$",
            "type": "string"
          },
          "timestampMs": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "stepId",
          "path",
          "timestampMs",
          "sha256"
        ],
        "type": "object"
      },
      "minItems": 3,
      "type": "array"
    },
    "storyboard": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "id",
        "sha256"
      ],
      "type": "object"
    },
    "verdict": {
      "const": "accepted",
      "type": "string"
    },
    "video": {
      "additionalProperties": false,
      "properties": {
        "codec": {
          "minLength": 1,
          "type": "string"
        },
        "durationMs": {
          "minimum": 0,
          "type": "number"
        },
        "durationToleranceUsed": {
          "type": "boolean"
        },
        "height": {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "sizeBytes": {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        "width": {
          "exclusiveMinimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "sha256",
        "durationMs",
        "durationToleranceUsed",
        "sizeBytes",
        "codec",
        "width",
        "height"
      ],
      "type": "object"
    }
  },
  "required": [
    "schemaVersion",
    "runId",
    "issue",
    "pullRequest",
    "proofClass",
    "acceptanceMappings",
    "git",
    "device",
    "runtime",
    "authority",
    "fixture",
    "action",
    "storyboard",
    "rehearsal",
    "video",
    "screenshots",
    "assertions",
    "eventTrace",
    "frameMatches",
    "contactSheet",
    "errorBaseline",
    "invalidationReasons",
    "evidenceReview",
    "verdict"
  ],
  "title": "FinalProofReceipt",
  "type": "object"
}
