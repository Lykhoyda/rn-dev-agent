# `.rn-agent/` scoped ignores
#
# This file lives inside .rn-agent/ so the plugin's gitignore policy
# is self-contained — no pollution of the project-root .gitignore.

# High-churn runtime state — per-developer, not shareable as code
state/
recordings/
snapshots/
diag/
index.json
local/

# Everything else is committable by default:
#   actions/         (the agent's compiled L3 flows)
#   skeleton.yaml    (UI skeleton, semantic testID map)
#   nav-graph.yaml   (cached navigation graph)
#   fixtures/        (replay seed data)
#   proposals/       (repair proposals queued for human review)
#   .scaffold-version (plugin scaffold version marker)
#   README.md        (self-documenting layout)
